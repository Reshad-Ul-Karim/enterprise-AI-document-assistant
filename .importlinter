; The core-purity contract.
;
; This is the single highest-leverage artifact in the repo. It is why:
;   * the whole test suite runs with NO API key and NO network (inject FakeGenerator);
;   * swapping the hosted Mistral API for self-hosted Apache-2.0 weights is a one-file
;     change -- which is the real answer to "where does our data go?";
;   * exposing retrieval over MCP would be a ~21-line adapter, not a refactor.
;
; The point is that none of those are README claims asking to be believed. The build fails
; if they stop being true. Wired into pytest (tests/test_architecture.py) so `pytest` alone
; proves it.
;
; Two gotchas that make copy-pasted configs fail:
;   * include_external_packages = True is REQUIRED when forbidding external modules.
;   * root_packages must be an indented list, not inline.

[importlinter]
root_packages =
    src
include_external_packages = True

[importlinter:contract:1]
name = core is protocol-free and provider-free
type = forbidden
source_modules =
    src.core
forbidden_modules =
    fastapi
    starlette
    uvicorn
    mcp
    pinecone
    mistralai
    langchain_text_splitters
allow_indirect_imports = False

[importlinter:contract:2]
name = layered
type = layers
layers =
    src.api
    src.ingest
    src.core

; CONTRACT 3 exists because contract 2 was not enough, and a failed deploy taught us that.
;
; `layers` permits a HIGHER layer to import a LOWER one, so `src.api -> src.ingest` was
; legal and lint-imports passed. But `src.ingest` imports PyMuPDF -- a BUILD-TIME
; dependency deliberately excluded from the runtime image. `api/main.py` imported MANIFEST
; from `ingest/extract.py`, the container built cleanly, and it died on boot with
; `ModuleNotFoundError: No module named 'pymupdf'`. Local tests passed the whole time,
; because a dev machine has PyMuPDF installed.
;
; The rule the layering contract MEANT to express is stronger than the one it stated:
; ingestion is an offline batch pipeline and serving is a stateless online service, so the
; serving layer must never import the build layer AT ALL. Shared things (the manifest, the
; page map, the models) belong in core/.
;
; This is the contract that would have caught it before the deploy did.

[importlinter:contract:3]
name = api never imports the build-time layer (ingest pulls PyMuPDF, which is not in the runtime image)
type = forbidden
source_modules =
    src.api
forbidden_modules =
    src.ingest
    pymupdf
    fitz
allow_indirect_imports = False
