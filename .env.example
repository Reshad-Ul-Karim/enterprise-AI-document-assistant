# Answer generation. Without it, retrieval / /health / the test suite still work.
MISTRAL_API_KEY=

# PINNED, never 'mistral-large-latest': an alias re-pointing mid-assessment is both a dead
# demo and an uncontrolled eval variable.
MISTRAL_MODEL=mistral-large-2512

# Mistral does not publish free-tier limits -- their docs tell you to read them off your own
# admin console. Observe yours, record the DATE, and set it here. Never hardcode a number
# from a blog post; the app honours whatever Retry-After the server actually sends.
MAX_CONCURRENT_REQUESTS=1
REQUESTS_PER_SECOND=1.0

# Uploaded knowledge bases only. Unset is a supported, tested state: the committed corpus
# and all six demo questions work with zero network calls.
PINECONE_API_KEY=
PINECONE_INDEX=eda-kb

# Auth gates the UPLOAD surface only -- the demo corpus is public and needs no login.
# A HASH, never a password: this repo is public.
#   python -c "import bcrypt;print(bcrypt.hashpw(b'YOUR_PW', bcrypt.gensalt(12)).decode())"
AUTH_EMAIL=
AUTH_PASSWORD_HASH=
#   python -c "import secrets;print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Uploaded KBs persist ONLY if this is set. Unset -> uploads are in-memory and die on
# restart, which the UI states at upload time rather than discovering later.
PINECONE_API_KEY=
